:1200,"col":"G","pos":10,"kind":"cab","id":"G10","kw":10},{"x":8500.0,"y":22100.0,"w":600,"h":1200,"col":"G","pos":11,"kind":"cab","id":"G11","kw":10},{"x":9100.0,"y":22100.0,"w":600,"h":1200,"col":"G","pos":12,"kind":"cab","id":"G12","kw":10},{"x":9700.0,"y":22100.0,"w":600,"h":1200,"col":"G","pos":13,"kind":"cab","id":"G13","kw":10},{"x":10300.0,"y":22100.0,"w":600,"h":1200,"col":"G","pos":14,"kind":"cab","id":"G14","kw":10},{"x":10900.0,"y":22100.0,"w":600,"h":1200,"col":"G","pos":15,"kind":"cab","id":"G15","kw":10},{"x":11500.0,"y":22100.0,"w":600,"h":1200,"col":"G","pos":16,"kind":"cab","id":"G16","kw":10},{"x":12100.0,"y":22100.0,"w":600,"h":1200,"col":"G","pos":17,"kind":"cab","id":"G17","kw":10},{"x":12700.0,"y":22100.0,"w":600,"h":1200,"col":"G","pos":18,"kind":"cab","id":"G18","kw":10},{"x":13300.0,"y":22100.0,"w":600,"h":1200,"col":"G","pos":19,"kind":"cab","id":"G19","kw":10},{"x":2000.0,"y":25100.0,"w":400,"h":1200,"kind":"pdu","id":"4PH","col":"H"},{"x":2500.0,"y":25100.0,"w":600,"h":1200,"col":"H","pos":1,"kind":"cab","id":"H01","kw":10},{"x":3100.0,"y":25100.0,"w":600,"h":1200,"col":"H","pos":2,"kind":"cab","id":"H02","kw":10},{"x":3700.0,"y":25100.0,"w":600,"h":1200,"col":"H","pos":3,"kind":"cab","id":"H03","kw":10},{"x":4300.0,"y":25100.0,"w":600,"h":1200,"col":"H","pos":4,"kind":"cab","id":"H04","kw":10},{"x":4900.0,"y":25100.0,"w":600,"h":1200,"col":"H","pos":5,"kind":"cab","id":"H05","kw":10},{"x":5500.0,"y":25100.0,"w":600,"h":1200,"col":"H","pos":6,"kind":"cab","id":"H06","kw":10},{"x":6100.0,"y":25100.0,"w":600,"h":1200,"col":"H","pos":7,"kind":"cab","id":"H07","kw":10},{"x":6700.0,"y":25100.0,"w":600,"h":1200,"col":"H","pos":8,"kind":"cab","id":"H08","kw":10},{"x":7300.0,"y":25100.0,"w":600,"h":1200,"col":"H","pos":9,"kind":"cab","id":"H09","kw":10},{"x":7900.0,"y":25100.0,"w":600,"h":1200,"col":"H","pos":10,"kind":"cab","id":"H10","kw":10},{"x":8500.0,"y":25100.0,"w":600,"h":1200,"col":"H","pos":11,"kind":"cab","id":"H11","kw":10},{"x":9100