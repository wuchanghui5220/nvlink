":"I13","kw":10},{"x":10300.0,"y":28100.0,"w":600,"h":1200,"col":"I","pos":14,"kind":"cab","id":"I14","kw":10},{"x":10900.0,"y":28100.0,"w":600,"h":1200,"col":"I","pos":15,"kind":"cab","id":"I15","kw":10},{"x":11500.0,"y":28100.0,"w":600,"h":1200,"col":"I","pos":16,"kind":"cab","id":"I16","kw":10},{"x":12100.0,"y":28100.0,"w":600,"h":1200,"col":"I","pos":17,"kind":"cab","id":"I17","kw":10},{"x":12700.0,"y":28100.0,"w":600,"h":1200,"col":"I","pos":18,"kind":"cab","id":"I18","kw":10},{"x":13300.0,"y":28100.0,"w":600,"h":1200,"col":"I","pos":19,"kind":"cab","id":"I19","kw":10}],"trays":[{"type":"polyline","points":[[1300,-1620.0],[1300,32420.0]],"width":600,"layer":"综合布线-主走线架","label":"主走600"},{"type":"polyline","points":[[14600,-1620.0],[14600,32420.0]],"width":600,"layer":"综合布线-主走线架","label":"主走600"},{"type":"polyline","points":[[1800,2600.0],[13600,2600.0]],"width":600,"layer":"综合布线-列走线架"},{"type":"polyline","points":[[1800,6500.0],[13600,6500.0]],"width":600,"layer":"综合布线-列走线架"},{"type":"polyline","points":[[1800,9500.0],[13600,9500.0]],"width":600,"layer":"综合布线-列走线架"},{"type":"polyline","points":[[1800,12800.0],[13600,12800.0]],"width":600,"layer":"综合布线-列走线架"},{"type":"polyline","points":[[1800,15800.0],[13600,15800.0]],"width":600,"layer":"综合布线-列走线架"},{"type":"polyline","points":[[1800,19100.0],[13600,19100.0]],"width":600,"layer":"综合布线-列走线架"},{"type":"polyline","points":[[1800,22100.0],[13600,22100.0]],"width":600,"layer":"综合布线-列走线架"},{"type":"polyline","points":[[1800,25100.0],[13600,25100.0]],"width":600,"layer":"综合布线-列走线架"},{"type":"polyline","points":[[1800,28100.0],[13600,28100.0]],"width":600,"layer":"综合布线-列走线架"},{"type":"polyline","points":[[-3000,-1620.0],[18000,-1620.0]],"width":600,"layer":"走廊主走线架","label":"北侧走廊主走线架"},{"type":"polyline","points":[[-3000,32420.0],[18000,32420.0]],"width":600,"layer":"走廊主走线架","label":"南侧走廊主走线架"},{"type":"polyline","points":[[1300,8450],[-8700,8450]],"width":600,"layer":"跨房穿孔线槽","label":"→ M403 内延 8250mm"},{"type":"polyline","points":[[1300,22900],[-8700,22900]],"width":600,"layer":"跨房穿孔线槽","label":"→ M403 内延 8250mm"}],"hot_aisles":[{"x":1800,"y":200,"w":11800,"h":1800,"label":"顶部封闭热通道 1800mm"},{"x":1800,"y":7100,"w":11800,"h":1800,"label":"微模块2 封闭热通道 1800mm"},{"x":1800,"y":13400,"w":11800,"h":1800,"label":"微模块3 封闭热通道 1800mm"},{"x":1800,"y":19700,"w":11800,"h":1800,"label":"微模块4 封闭热通道 1800mm"},{"x":1800,"y":25700,"w":11800,"h":1800,"label":"微模块5 封闭热通道 1800mm"}],"rows":[{"y":2600.0,"col":"A","micro":1},{"y":6500.0,"col":"B","micro":2},{"y":9500.0,"col":"C","micro":2},{"y":12800.0,"col":"D","micro":3},{"y":15800.0,"col":"E","micro":3},{"y":19100.0,"col":"F","micro":4},{"y":22100.0,"col":"G","micro":4},{"y":25100.0,"col":"H","micro":5},{"y":28100.0,"col":"I","micro":5}],"micro_summary":"M1=A, M2=B+C, M3=D+E, M4=F+G, M5=H+I","cross_extents":[{"x":-8700,"y":8450,"side":"west","to":"M403"},{"x":-8700,"y":22900,"side":"west","to":"M403"}],"ports":[{"wall":"N","x":1300,"width":600,"to":"corridor-N"},{"wall":"S","x":1300,"width":600,"to":"corridor-S"},{"wall":"N","x":14600,"width":600,"to":"corridor-N"},{"wall":"S","x":14600,"width":600,"to":"corridor-S"},{"wall":"W","y":8450,"width":600,"to":"M403"},{"wall":"W","y":22900,"width":600,"to":"M403"}],"adjacency":{"E":[],"W":["M403"],"N":["corridor-N"],"S":["corridor-S"]},"cab_h":1200,"pdu_w":400,"cab_count":167,"pdu_count":9,"pillar_count":4,"tray_count":15,"hot_aisle_count":5,"cross_count":2,"port_count":6}]}
