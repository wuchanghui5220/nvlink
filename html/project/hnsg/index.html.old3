<!doctype html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<title>华南数谷 1 栋三层/四层 IT 机房布局（临摹版）</title>
<style>
:root {
  --bg:#f4f4f4; --panel:#fff; --border:#ccc;
  --tab-bg:#e6e6e6; --tab-active:#fff;
  --text:#222; --muted:#777;
  --cab:#4a90e2; --cab-stroke:#1f4e85;
  --pdu:#f5a623; --pdu-stroke:#a26200;
  --pillar:#3a3a3a; --pillar-stroke:#000;
  --tray-list:#2ca02c; --tray-main:#d62728;
  --tray-corridor:#7a1a1a;
  --tray-cross:#8e44ad;
  --hot-fill:rgba(255,80,80,0.18); --hot-stroke:#c0392b;
  --wall:#555; --wall-fill:#d8d8d8;
}
html,body{margin:0;padding:0;background:var(--bg);color:var(--text);
  font-family:-apple-system,"PingFang SC",sans-serif;font-size:13px;}
header{padding:8px 16px;background:#2c3e50;color:#fff;}
header h1{margin:0;font-size:16px;font-weight:500;}
header .src{color:#aac;font-size:11px;margin-top:2px;}
.tabs{display:flex;gap:2px;padding:8px 16px 0;background:var(--bg);flex-wrap:wrap;}
.tabs button{padding:8px 18px;border:1px solid var(--border);border-bottom:none;
  background:var(--tab-bg);cursor:pointer;font:inherit;border-radius:4px 4px 0 0;}
.tabs button.active{background:var(--tab-active);font-weight:600;}
.panel{display:none;padding:12px 16px 16px;background:var(--panel);
  border-top:1px solid var(--border);}
.panel.active{display:block;}
.warn{background:#fff3cd;border:1px solid #ffc107;padding:8px 12px;margin:8px 0;
  border-radius:4px;color:#664d03;font-size:12px;}
.subtabs{display:flex;gap:2px;margin-bottom:8px;}
.subtabs button{padding:6px 14px;border:1px solid var(--border);
  background:#f0f0f0;cursor:pointer;font:inherit;border-radius:3px;}
.subtabs button.active{background:#2c3e50;color:#fff;border-color:#2c3e50;}
.meta{color:var(--muted);margin:4px 0 8px;font-size:12px;line-height:1.6;}
.meta b{color:var(--text);}
.canvas-wrap{background:#fafafa;border:1px solid var(--border);padding:8px;overflow:auto;}
svg{display:block;background:#fff;}
.legend{display:flex;flex-wrap:wrap;gap:12px;margin-top:8px;font-size:12px;color:var(--muted);}
.legend span{display:inline-flex;align-items:center;gap:4px;}
.legend i{display:inline-block;width:14px;height:8px;border:1px solid #333;}
.empty{padding:32px;text-align:center;color:var(--muted);}
</style>
</head>
