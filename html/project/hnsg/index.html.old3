<script>
const data = JSON.parse(document.getElementById("layout-data").textContent);
document.getElementById("src-info").textContent =
  "来源: " + (data.source || "?") + " · 生成: " + (data.generated || "?");

const TRAY_COLOR = {
  "综合布线-列走线架":"var(--tray-list)",
  "综合布线-主走线架":"var(--tray-main)",
  "走廊主走线架":"var(--tray-corridor)",
  "跨房穿孔线槽":"var(--tray-cross)",
};
const PADDING = 1500;
const SVG_PIXEL_PER_MM = 0.04;
const STROKE_MM = 50;

function svgEl(name, attrs, children) {
  const el = document.createElementNS("http://www.w3.org/2000/svg", name);
  for (const k in attrs) el.setAttribute(k, attrs[k]);
  if (children) for (const c of children) el.appendChild(c);
  return el;
}

function renderCabinet(c) {
  const x = c.x - c.w/2, y = c.y - c.h/2;
  const g = svgEl("g", {});
  let fill, stroke;
  if (c.kind === "pillar") {
    fill = "var(--pillar)"; stroke = "var(--pillar-stroke)";
  } else if (c.kind === "pdu") {
    fill = "var(--pdu)"; stroke = "var(--pdu-stroke)";
  } else {
    fill = "var(--cab)"; stroke = "var(--cab-stroke)";
  }
  g.appendChild(svgEl("rect", {
    x, y, width:c.w, height:c.h,
    fill, stroke, "stroke-width": STROKE_MM/2,
  }));
  if (c.kind === "pillar") {
    // 立柱画对角斜线
    g.appendChild(svgEl("line", {
      x1:x, y1:y, x2:x+c.w, y2:y+c.h,
      stroke:"#fff", "stroke-width":40, opacity:0.6,
    }));
    g.appendChild(svgEl("line", {
      x1:x+c.w, y1:y, x2:x, y2:y+c.h,
      stroke:"#fff", "stroke-width":40, opacity:0.6,
    }));
  }
  if (c.id) {
    const t = svgEl("text", {
      x: c.x, y: c.y + 60,
      "text-anchor":"middle", "font-size":180,
      fill:"#fff", "font-weight":"bold",
    });
    t.textContent = c.kind === "pillar" ? "柱" : c.id;
    g.appendChild(t);
  }
  return g;
}

function renderHotAisle(h) {
  const g = svgEl("g", {});
  g.appendChild(svgEl("rect", {
    x:h.x, y:h.y, width:h.w, height:h.h,
    fill:"var(--hot-fill)", stroke:"var(--hot-stroke)",
    "stroke-width":40, "stroke-dasharray":"160 80",
  }));
  // 斜线填充图案（用多条线模拟）
  const stripe = 600;
  for (let s = -h.h; s < h.w; s += stripe) {
    const x1 = h.x + s,        y1 = h.y;
    const x2 = h.x + s + h.h,  y2 = h.y + h.h;
    // 裁剪到矩形内
    const cx1 = Math.max(h.x, x1);
    const cy1 = y1 + (cx1 - x1);
    const cx2 = Math.min(h.x + h.w, x2);
    const cy2 = y2 - (x2 - cx2);
    if (cx1 < cx2 && cy1 < h.y + h.h) {
      g.appendChild(svgEl("line", {
        x1:cx1, y1:cy1, x2:cx2, y2:cy2,
        stroke:"var(--hot-stroke)", "stroke-width":15, opacity:0.4,
      }));
    }
  }
  // 居中文字
  if (h.w > 3000) {
    const t = svgEl("text", {
      x:h.x + h.w/2, y:h.y + h.h/2 + 100,
      "text-anchor":"middle", "font-size":380,
      fill:"var(--hot-stroke)", "font-weight":"bold",
    });
    t.textContent = h.label || "热通道";
    g.appendChild(t);
  }
  return g;
}

function renderPort(p, room) {
  const wt = room.wall_thickness;
  const W = room.size.w, H = room.size.h;
  const half = (p.width || 600) / 2;
  const tip = 350;  // 三角朝外突出量
  let pts;
  if (p.wall === "N") {
    pts = [[p.x-half, 0], [p.x+half, 0], [p.x, -tip]];
  } else if (p.wall === "S") {
    pts = [[p.x-half, H], [p.x+half, H], [p.x, H+tip]];
  } else if (p.wall === "E") {
    pts = [[W, p.y-half], [W, p.y+half], [W+tip, p.y]];
  } else if (p.wall === "W") {
    pts = [[0, p.y-half], [0, p.y+half], [-tip, p.y]];
  } else return svgEl("g", {});
  return svgEl("polygon", {
    points: pts.map(p => `${p[0]},${p[1]}`).join(" "),
    fill: "var(--tray-cross)", stroke: "#333", "stroke-width": 30,
    opacity: 0.85,
  });
}

function renderTray(t) {
  const color = TRAY_COLOR[t.layer] || "#666";
  const w = t.width || STROKE_MM;
  const g = svgEl("g", {});
  for (let i = 0; i < t.points.length - 1; i++) {
    const [x1, y1] = t.points[i];
    const [x2, y2] = t.points[i+1];
    const dx = x2 - x1, dy = y2 - y1;
    const len = Math.hypot(dx, dy);
    if (len === 0) continue;
    const px = -dy / len * w / 2;
    const py = dx / len * w / 2;
    const pts = [
      [x1 + px, y1 + py],
      [x2 + px, y2 + py],
      [x2 - px, y2 - py],
      [x1 - px, y1 - py],
    ].map(p => `${p[0]},${p[1]}`).join(" ");
    g.appendChild(svgEl("polygon", {
      points: pts,
      fill: color, "fill-opacity": 0.12,
      stroke: color, "stroke-width": 50, "stroke-opacity": 0.95,
    }));
  }
  return g;
}

function renderRoomView(room, mode) {
  const wrap = document.createElement("div");
  wrap.className = "canvas-wrap";
  const W = room.size.w, H = room.size.h;
  // 包含走廊（南北墙外）+ 跨房延伸
  const yTop = Math.min(0, room.corridor_y_north) - PADDING;
  const yBot = Math.max(H, room.corridor_y_south) + PADDING;
  let xMin = 0, xMax = W;
  for (const ce of (room.cross_extents||[])) {
    if (ce.x < xMin) xMin = ce.x;
    if (ce.x > xMax) xMax = ce.x;
  }
  const xLeft  = xMin - PADDING - 1000;
  const xRight = xMax + PADDING + 1000;
  const VBW = xRight - xLeft, VBH = yBot - yTop;
  const svg = svgEl("svg", {
    viewBox: `${xLeft} ${yTop} ${VBW} ${VBH}`,
    width:  Math.max(900, VBW * SVG_PIXEL_PER_MM),
    height: Math.max(500, VBH * SVG_PIXEL_PER_MM),
  });

  // 墙体（北/南墙）
  const wt = room.wall_thickness;
  // 北墙：y ∈ [-wt, 0]
  svg.appendChild(svgEl("rect", {
    x:0, y:-wt, width:W, height:wt,
    fill:"var(--wall-fill)", stroke:"var(--wall)", "stroke-width":STROKE_MM,
  }));
  // 南墙
  svg.appendChild(svgEl("rect", {
    x:0, y:H, width:W, height:wt,
    fill:"var(--wall-fill)", stroke:"var(--wall)", "stroke-width":STROKE_MM,
  }));

  // 房间外框（含东西墙仅画线）
  svg.appendChild(svgEl("rect", {
    x:0, y:0, width:W, height:H,
    fill:"#fff", stroke:"var(--wall)", "stroke-width":STROKE_MM,
  }));

  // 网格 1m
  const GRID = 1000;
  for (let x = 0; x <= W; x += GRID) {
    svg.appendChild(svgEl("line", {
      x1:x, y1:0, x2:x, y2:H,
      stroke:"#eee", "stroke-width":20,
    }));
  }
  for (let y = 0; y <= H; y += GRID) {
    svg.appendChild(svgEl("line", {
      x1:0, y1:y, x2:W, y2:y,
      stroke:"#eee", "stroke-width":20,
    }));
  }

  // 热通道
  if (mode === "cabinets" || mode === "both") {
    for (const h of (room.hot_aisles||[])) svg.appendChild(renderHotAisle(h));
  }
  if (mode === "cabinets" || mode === "both") {
    for (const c of room.cabinets) svg.appendChild(renderCabinet(c));
    // 列字母（每行左侧）
    for (const r of (room.rows||[])) {
      const t = svgEl("text", {
        x: room.aisles.left - 250, y: r.y + 100,
        "text-anchor":"end", "font-size":500,
        fill:"#c0392b", "font-weight":"bold",
      });
      t.textContent = r.col;
      svg.appendChild(t);
    }
  }
  if (mode === "trays" || mode === "both") {
    for (const t of room.trays) svg.appendChild(renderTray(t));
    // 跨房穿孔线槽端点标注
    for (const ce of (room.cross_extents||[])) {
      const t = svgEl("text", {
        x: ce.x + (ce.side === "east" ? 200 : -200),
        y: ce.y - 200,
        "text-anchor": ce.side === "east" ? "start" : "end",
        "font-size": 350, fill: "var(--tray-cross)",
        "font-weight":"bold",
      });
      t.textContent = ce.side === "east" ? `→ ${ce.to}` : `${ce.to} ←`;
      svg.appendChild(t);
    }
    // 出线孔（墙上小三角，向外指）
    for (const p of (room.ports||[])) svg.appendChild(renderPort(p, room));
  }

  // 比例尺 5m
  const sx = xLeft + 800, sy = yBot - 800;
  svg.appendChild(svgEl("line", {
    x1:sx, y1:sy, x2:sx+5000, y2:sy,
    stroke:"#333", "stroke-width":80,
  }));
  const txt = svgEl("text", {
    x:sx+2500, y:sy-200, "text-anchor":"middle",
    "font-size":350, fill:"#333",
  });
  txt.textContent = "5m";
  svg.appendChild(txt);

  // 房间标签（居中放在北走廊上方，避开主走线架）
  const lbl = svgEl("text", {
    x:W/2, y:room.corridor_y_north - 900,
    "text-anchor":"middle", "font-size":700,
    fill:"#333", "font-weight":"bold",
  });
  lbl.textContent = `${room.name}  ${(W/1000).toFixed(1)}×${(H/1000).toFixed(1)}m`;
  svg.appendChild(lbl);

  // 走廊标签
  const nL = svgEl("text", {
    x:W/2, y:room.corridor_y_north - 250,
    "text-anchor":"middle", "font-size":350, fill:"#666",
  });
  nL.textContent = "北侧走廊";
  svg.appendChild(nL);
  const sL = svgEl("text", {
    x:W/2, y:room.corridor_y_south + 600,
    "text-anchor":"middle", "font-size":350, fill:"#666",
  });
  sL.textContent = "南侧走廊";
  svg.appendChild(sL);

  wrap.appendChild(svg);
  return wrap;
}

function makeLegend(mode) {
  const div = document.createElement("div");
  div.className = "legend";
  if (mode === "cabinets") {
    div.innerHTML = `
      <span><i style="background:var(--cab)"></i> IT 机柜 (600×1100)</span>
      <span><i style="background:var(--pdu)"></i> PDU 列头柜 (400×1100)</span>
      <span><i style="background:var(--pillar)"></i> 建筑立柱（占柜位）</span>
      <span><i style="background:var(--hot-fill);border-color:var(--hot-stroke)"></i> 封闭热通道 (1.2m)</span>
    `;
  } else if (mode === "trays") {
    div.innerHTML = `
      <span><i style="background:var(--tray-list)"></i> 列走线架 (600mm)</span>
      <span><i style="background:var(--tray-main)"></i> 主走线架 (600mm,机房内)</span>
      <span><i style="background:var(--tray-cross)"></i> 跨房穿孔线槽 (600mm,相邻机房)</span>
      <span><i style="background:var(--tray-corridor)"></i> 走廊主走线架 (600mm,跨机房备路)</span>
    `;
  } else {
    div.innerHTML = `
      <span><i style="background:var(--cab)"></i> IT 柜</span>
      <span><i style="background:var(--pdu)"></i> PDU</span>
      <span><i style="background:var(--pillar)"></i> 立柱</span>
      <span><i style="background:var(--hot-fill);border-color:var(--hot-stroke)"></i> 热通道</span>
      <span><i style="background:var(--tray-main)"></i> 主走线架</span>
      <span><i style="background:var(--tray-list)"></i> 列走线架</span>
      <span><i style="background:var(--tray-cross)"></i> 跨房穿孔</span>
      <span><i style="background:var(--tray-corridor)"></i> 走廊线槽</span>
    `;
  }
  return div;
}

function buildPanel(room) {
  const panel = document.createElement("div");
  panel.className = "panel";

  if (room.label) {
    const w = document.createElement("div");
    w.className = "warn";
    w.innerHTML = `<b>${room.name}</b>  ${room.label}`;
    panel.appendChild(w);
  }

  const meta = document.createElement("div");
  meta.className = "meta";
  const L = room.layout;
  meta.innerHTML = `
    尺寸: <b>${room.size.w/1000}m × ${room.size.h/1000}m</b> ·
    过道: 左<b>${room.aisles.left/1000}</b>m / 右<b>${room.aisles.right/1000}</b>m / 底<b>${room.aisles.bottom/1000}</b>m ·
    墙厚 ${room.wall_thickness}mm<br>
    分组: <b>${room.micro_summary}</b><br>
    每列 <b>${L.cabs_per_row}</b> 柜位 + 西侧 1 个 ${room.pdu_w||400}mm PDU ·
    机柜深 <b>${room.cab_h||1200}</b>mm ·
    共 <b>${room.cab_count}</b> IT / <b>${room.pdu_count}</b> PDU / <b>${room.pillar_count}</b> 立柱 ·
    <b>${room.hot_aisle_count}</b> 段封闭热通道 / <b>${room.tray_count}</b> 段线槽
    （含 <b>${room.cross_count||0}</b> 段跨房穿孔）<br>
    出线孔 <b>${room.port_count||0}</b> 个 ·
    邻接: E→${(room.adjacency.E||[]).join(",")||"—"} | W→${(room.adjacency.W||[]).join(",")||"—"} | N→走廊 | S→走廊
  `;
  panel.appendChild(meta);

  const subtabs = document.createElement("div");
  subtabs.className = "subtabs";
  const modes = [
    {key:"cabinets", label:"机柜布局"},
    {key:"trays",    label:"线槽布局"},
    {key:"both",     label:"叠加视图"},
  ];
  const viewWrap = document.createElement("div");
  function showMode(key) {
    viewWrap.innerHTML = "";
    viewWrap.appendChild(renderRoomView(room, key));
    viewWrap.appendChild(makeLegend(key));
    subtabs.querySelectorAll("button").forEach(b =>
      b.classList.toggle("active", b.dataset.mode === key));
  }
  modes.forEach(m => {
    const btn = document.createElement("button");
    btn.dataset.mode = m.key;
    btn.textContent = m.label;
    btn.onclick = () => showMode(m.key);
    subtabs.appendChild(btn);
  });
  panel.appendChild(subtabs);
  panel.appendChild(viewWrap);
  showMode("cabinets");
  return panel;
}

function build() {
  const tabs = document.getElementById("room-tabs");
  const panels = document.getElementById("panels");
  if (!data.rooms || data.rooms.length === 0) {
    panels.innerHTML = '<div class="empty">无房间数据</div>';
    return;
  }
  data.rooms.forEach((room, i) => {
    const btn = document.createElement("button");
    btn.textContent = `${room.name} (${room.cab_count}柜)`;
    btn.onclick = () => {
      tabs.querySelectorAll("button").forEach(b => b.classList.remove("active"));
      panels.querySelectorAll(".panel").forEach(p => p.classList.remove("active"));
      btn.classList.add("active");
      panels.querySelectorAll(".panel")[i].classList.add("active");
    };
    if (i === 0) btn.classList.add("active");
    tabs.appendChild(btn);

    const p = buildPanel(room);
    if (i === 0) p.classList.add("active");
    panels.appendChild(p);
  });
}
build();
</script>
</body>
</html>
